  "keyFeatures": [
    "Bot lifecycle management (create, start, stop, restart, upgrade, delete)",
    "Kubernetes-native orchestration with isolated Pod per bot",
    "Multi-tenant app-level isolation with per-user bot ownership",
    "Dynamic skills management for running bots",
    "IM channel integrations (Telegram, Slack, Discord, Teams, LINE, Feishu)",
    "Device pairing with auto-approval support",
    "Multi-provider AI model configuration (Anthropic, OpenAI, MiniMax, etc.)",
    "HTTP and WebSocket proxy with subdomain routing",
    "Built-in Next.js admin UI embedded in Go binary",
    "Helm chart and raw K8s manifest deployment options"
  ],
  "publicApiSurface": [
    "POST /bot/api/v1/admin/apps",
    "GET /bot/api/v1/admin/apps",
    "GET /bot/api/v1/admin/apps/:id",
